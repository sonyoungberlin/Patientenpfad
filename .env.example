# ---------------------------------------------------------------------------
# Datenbankverbindung (Prisma)
# ---------------------------------------------------------------------------
#
# Neon / Vercel-Postgres liefert automatisch POSTGRES_PRISMA_URL (pooled) und
# POSTGRES_URL_NON_POOLING (direct). Diese müssen explizit auf die unten
# stehenden stabilen Namen gemappt werden (Vercel → Settings → Environment
# Variables):
#
#   DATABASE_URL        = <Wert von POSTGRES_PRISMA_URL>
#   DIRECT_DATABASE_URL = <Wert von POSTGRES_URL_NON_POOLING>
#
# Beide URLs sollten den Query-Parameter connect_timeout=15 enthalten, damit
# Neon-Compute-Instanzen nach einem Scale-to-zero genug Zeit zum Aufwachen
# haben (verhindert P1001-Fehler).
# ---------------------------------------------------------------------------

# Laufzeit-Queries – darf über den Connection-Pooler gehen.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?connect_timeout=15"

# Direkte Verbindung ohne Connection-Pooler.
# Wird von Prisma Migrate / prisma migrate deploy verwendet.
# WICHTIG: Migrationen niemals gegen eine Pooler-URL ausführen!
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?connect_timeout=15"

# ---------------------------------------------------------------------------
# Mail-Transport
# ---------------------------------------------------------------------------
# Wird von lib/mail/sendWebsiteFormConfirmationEmail.ts ausgewertet.
#
#   MAIL_TRANSPORT=console (Default, auch wenn Variable nicht gesetzt)
#     Bestätigungs-E-Mails werden NICHT versendet, sondern als
#     console.info-Eintrag inkl. Bestätigungs-URL geloggt. Geeignet für
#     lokale Entwicklung und Tests ohne SMTP. Wird auch dann verwendet,
#     wenn eine Practice keine eigene SMTP-Konfig hat (Fallback).
#
#   MAIL_TRANSPORT=smtp
#     Bestätigungs-E-Mails werden über einen echten SMTP-Server versendet.
#     Erfordert die untenstehenden SMTP_*-Variablen. Bei fehlender oder
#     ungültiger Konfiguration wird KEIN stilles Fallback auf "console"
#     vorgenommen — der Mailversand schlägt fehl, der Submit-Endpoint
#     loggt strukturiert `outcome=mail_failed` und liefert dem Patienten
#     trotzdem den generischen Erfolgs-Redirect (Session bleibt erhalten).
#     Hinweis: Practice-spezifische SMTP-Konfig hat IMMER Vorrang. Dieser
#     Wert ist Übergangs-Fallback für Practices ohne eigene Konfig.
#
#   MAIL_TRANSPORT=practice_only
#     Strict-Mode (empfohlen für Production nach abgeschlossener Migration):
#     es wird AUSSCHLIESSLICH über die Practice-SMTP-Konfig versendet.
#     Practices ohne vollständige Konfig führen zu `outcome=mail_failed` —
#     Session bleibt in `awaiting_email_confirmation`, kein Versand über
#     globale SMTP_*-ENV. Verhindert Cross-Tenant-Versand.
#
# Andere Werte führen zu einer Warnung im Server-Log und Fallback auf
# console.
#
# Vollständige Doku (Werte, Datenflüsse, Fehlerverhalten, Vercel-Setup):
# docs/website-forms-mail.md
# Operatives (Log-Marker, Cleanup-Runbook): docs/website-forms-operations.md
MAIL_TRANSPORT="console"

# ---------------------------------------------------------------------------
# SMTP-Konfiguration (nur ausgewertet, wenn MAIL_TRANSPORT=smtp)
# ---------------------------------------------------------------------------
# Alle SMTP_*-Variablen unten sind Pflicht, wenn MAIL_TRANSPORT=smtp gesetzt
# ist. SMTP_SECURE ist optional. Werte werden niemals in Server-Logs
# ausgegeben (insbesondere nicht SMTP_PASS).
#
# SMTP_HOST     Hostname des SMTP-Servers (z. B. smtp.example.com).
# SMTP_PORT     TCP-Port (typisch 465 für TLS, 587 für STARTTLS).
# SMTP_USER     SMTP-Login.
# SMTP_PASS     SMTP-Passwort. Geheim. Nur als Vercel-Secret hinterlegen.
# SMTP_FROM     Absenderadresse (Header "From"), idealerweise mit Display-
#               Name, z. B. "Praxis <noreply@example.com>".
# SMTP_SECURE   "true" → impliziertes TLS (Port 465).
#               "false" oder nicht gesetzt → STARTTLS (Port 587).
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
SMTP_SECURE="false"

# ---------------------------------------------------------------------------
# Mail-Secret-Key für Practice-spezifische SMTP-Passwörter
# ---------------------------------------------------------------------------
# Wird von lib/mail/smtpSecret.ts ausgewertet. Pflicht, sobald in /admin/
# practices/[id] SMTP-Passwörter gesetzt werden sollen — diese werden mit
# AES-256-GCM verschlüsselt in `Practice.smtp_pass_encrypted` abgelegt
# (Format: `v1:<base64(iv)>:<base64(ciphertext)>:<base64(authTag)>`).
#
# Pflicht-Format: 32 Bytes (Base64-kodiert).
# Generierung:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#
# Rotation: niemals löschen, ohne vorher Cipher zu re-encryptieren — sonst
# sind alle bestehenden Practice-Passwörter unentschlüsselbar (Submits
# laufen dann in `mail_failed`, Sessions bleiben erhalten).
MAIL_SECRET_KEY=""
