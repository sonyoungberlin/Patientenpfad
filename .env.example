# Datenbankverbindung (Prisma) – Laufzeit-Queries (darf Connection-Pooler sein)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# Direkte Verbindung ohne Connection-Pooler (für Migrationen).
# Falls nicht gesetzt, wird DATABASE_URL auch für Migrationen verwendet.
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"
