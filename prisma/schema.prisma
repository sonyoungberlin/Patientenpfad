generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum StageStatus {
  INTAKE
  PREFILL
  REVIEW
  READY
  CLOSED
}

/// Phase P1: Rolle einer Account-Practice-Mitgliedschaft.
/// In P1 wird ausschließlich `OWNER` per Backfill vergeben.
/// `ADMIN` und `USER` sind im Schema reserviert, werden aber erst in
/// späteren Phasen (P2 / P4) verwendet.
enum PracticeRole {
  OWNER
  ADMIN
  USER
}

model Account {
  id          String  @id @default(cuid())
  email       String  @unique
  is_approved Boolean @default(false)
  is_admin    Boolean @default(false)

  /// Passwort-Hash im kompakten Format `scrypt$N$r$p$saltBase64$hashBase64`
  /// (siehe `lib/password.ts`). NULL bedeutet: Account hat (noch) kein
  /// Passwort gesetzt; Login schlägt für solche Accounts neutral mit
  /// „E-Mail oder Passwort ungültig" fehl. Klartext-Passwörter werden niemals
  /// gespeichert oder geloggt.
  password_hash String?

  /// Einmal-Token für „Passwort setzen per Link"-Flow.
  /// Wird vom Endpoint `POST /api/auth/request-password-setup` erzeugt
  /// (`crypto.randomBytes`, hex-kodiert) und vom Endpoint
  /// `POST /api/auth/set-password` konsumiert (Token + Expiry werden nach
  /// erfolgreichem Setzen auf NULL gesetzt). NULL bedeutet: kein offener
  /// Setup-Link. Der Klartext-Token wird ausschließlich per Mail an die
  /// E-Mail-Adresse des Accounts versandt — niemals geloggt.
  password_reset_token   String?   @unique
  password_reset_expires DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  /// Freitext-Signatur für Nachrichten (max. 300 Zeichen, accountbezogen)
  message_signature String?

  /// Freigabe für den Anfrage-Assistenten (separater zweiter Modus).
  /// Muss explizit durch Admin aktiviert werden; Standard: false.
  inquiry_assistant_enabled Boolean @default(false)

  /// Freigabe für die Patientenkommunikation (Patientenfragebogen-Funktionen).
  /// Muss explizit durch Admin aktiviert werden; Standard: false.
  /// Backfill: Bestandsaccounts mit is_approved = true erhalten true (siehe Migration).
  patient_communication_enabled Boolean @default(false)

  /// Phase 3a: Freigabe für öffentliche Website-Fragebögen
  /// (`PracticeQuestionnaireForm` + `PatientQuestionnaireSession.source = "website"`).
  /// Muss explizit durch Admin aktiviert werden; Standard: false.
  /// Kein Backfill — die Funktion startet für alle Accounts deaktiviert.
  /// Es gibt bewusst keinen Admin-Bypass; auch Admins müssen diesen Flag tragen.
  website_forms_enabled Boolean @default(false)

  cases                          CaseSession[]
  sessions                       Session[]
  inquiry_sessions               InquirySession[]
  patient_questionnaire_sessions PatientQuestionnaireSession[]
  practice_questionnaire_forms   PracticeQuestionnaireForm[]

  /// Phase P1: Mitgliedschaften des Accounts in Practices.
  /// Wird per Backfill zunächst genau einmal pro Account mit Rolle
  /// `OWNER` befüllt. App-Logik nutzt diese Beziehung in P1 noch nicht;
  /// `owner_account_id` bleibt führend.
  memberships PracticeMembership[]

  /// Option C (minimal): Standard-Praxis dieses Accounts. Reine
  /// Auswahlhilfe für `current_practice` — gewinnt in
  /// `pickCurrentMembership` vor OWNER und vor der ältesten Membership,
  /// **sofern** der Account dort tatsächlich Mitglied ist. Ungültige
  /// Werte werden in der Auswahl-Logik stillschweigend ignoriert
  /// (Fallback auf bisheriges Verhalten). Wird ausschließlich vom
  /// Plattform-Admin via `/admin/practices/[id]` gesetzt; es gibt
  /// keinen Nutzer-seitigen Praxis-Wechsler. `onDelete: SetNull` schützt
  /// vor Inkonsistenzen, falls eine Practice je gelöscht wird.
  default_practice_id String?
  default_practice    Practice? @relation("AccountDefaultPractice", fields: [default_practice_id], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([default_practice_id])
}

model Session {
  id         String   @id @default(cuid())
  token      String   @unique
  account_id String
  account    Account  @relation(fields: [account_id], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  expiresAt  DateTime
}

/// Ein einzelner Vorbereitungsdurchlauf eines Falls (MFA, Patientengespräch,
/// Patientenfragebogen, …). Ein Fall kann mehrere nacheinander abgeschlossene
/// Runs haben. Ein eingefrorener Run (`frozen_at IS NOT NULL`) ist
/// unveränderlich. Pro Fall darf höchstens **ein** offener Run
/// (`frozen_at IS NULL`) existieren – durchgesetzt über einen partiellen
/// Unique-Index in der Migration (Prisma kennt partielle Unique-Indexe nicht
/// nativ). Die Reihenfolge wird über `sequence` (1..n, lückenfrei pro Fall)
/// abgebildet.
model PrefillRun {
  id String @id @default(cuid())

  /// Fall, zu dem dieser Run gehört.
  case_id String
  case    CaseSession @relation(fields: [case_id], references: [id], onDelete: Cascade)

  /// Position innerhalb des Falls (1..n, monoton, lückenfrei).
  sequence Int

  /// Quelle/Modus des Runs: "mfa" | "conversation" | "patient".
  /// Kein DB-Enum, weil das Schwester-Feld `CaseSession.preparation_mode`
  /// ebenfalls als String geführt wird; Whitelist-Validierung erfolgt in
  /// der Service-Schicht.
  source String

  /// Snapshot der zum Zeitpunkt des Runs aktiven Checkpoints
  /// (Form analog `CaseSession.active_checkpoints`). Dadurch werden
  /// eingefrorene Runs nicht durch spätere M1-Änderungen umgedeutet.
  active_checkpoints Json

  /// Antworten dieses Runs. Form analog `CaseSession.ctx_prefill`:
  /// `{ [checkpointId]: { [questionId]: "ja" | "nein" | "unklar" | "offen" } }`.
  answers Json

  created_at DateTime @default(now())

  /// Zeitpunkt des Einfrierens. `NULL` = offener Run.
  frozen_at DateTime?

  /// Account, der den Run angelegt hat. NULL bei Patientenrücklauf via Token.
  created_by_account_id String?

  /// Optionales Audit: Token-Wert, mit dem ein Patientenrücklauf zugeordnet
  /// wurde. NULL bei MFA-/Conversation-Runs.
  patient_token_used String?

  @@unique([case_id, sequence])
  @@index([case_id, frozen_at, sequence])
}

model CaseSession {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Roheingabe / Anlass der Session (neutraler Freitext)
  query_raw String?

  /// Grober Workflow-Status
  stage_status StageStatus @default(INTAKE)

  /// Übersicht der Block-Zustände (JSON-Anker)
  block_status_anchor Json?

  /// Aktive Checkpoints im aktuellen Workflow-Schritt (JSON-Anker)
  active_checkpoints Json?

  /// Prefill- / Kontextdaten für Blöcke (JSON-Anker)
  ctx_prefill Json?

  /// Bestätigte finale Daten der Session (JSON-Anker)
  ctx_final Json?

  /// Optionale Zusammenfassung / Summary (JSON-Anker)
  summary_anchor Json?

  /// Eingefrorener M1-Aktivierungsstand bei Fallanlage (unveränderlich nach Erstellung)
  m1_snapshot_initial Json?

  /// Startmodus: "guest" (kein Patientenbezug) oder "practice" (Praxiszuordnung)
  mode String? @default("guest")

  /// Optionale Patientennummer / Referenz (nur bei mode = "practice")
  patient_reference String?

  /// Verknüpfung zum eingeloggten Account (optional, bestehende Fälle bleiben erhalten)
  owner_account_id String?
  owner_account    Account? @relation(fields: [owner_account_id], references: [id], onDelete: SetNull)

  /// Phase P1 (additiv): Verknüpfung zum Mandanten (Practice). Wird per
  /// Backfill aus der OWNER-Membership zum bisherigen `owner_account_id`
  /// abgeleitet. App-Logik nutzt dieses Feld in P1 noch nicht; alle
  /// Lese-/Schreibpfade laufen weiterhin über `owner_account_id`.
  owner_practice_id String?
  owner_practice    Practice? @relation("CaseSessionOwnerPractice", fields: [owner_practice_id], references: [id], onDelete: SetNull)

  /// Einmaliges Token für den patientenseitigen M2-Link (ohne Login)
  m2_token String? @unique

  /// Ablaufdatum des M2-Tokens (14 Tage ab Erstellung)
  m2_token_expires_at DateTime?

  /// Status des Patientenfragebogens: none | waiting_for_patient | skipped | completed
  m2_status String @default("none")

  /// Vorbereitungsweg: none | mfa | patient | skipped
  preparation_mode String @default("none")

  /// Ärztliche Bestätigung: nach Klick auf „Ärztlich bestätigt" wird M3 eingefroren.
  doctor_confirmed Boolean @default(false)

  /// Zeitpunkt der ärztlichen Bestätigung (gesetzt zusammen mit doctor_confirmed=true).
  doctor_confirmed_at DateTime?

  /// Ärztlicher Workflow-Zwischenstatus: none | prepared | confirmed
  /// - "prepared" : Arzt hat in M3 vorbereitet / Lücken markiert (MFA übernimmt weiter)
  /// - "confirmed": Arzt hat M3 final geprüft (fachlicher Abschluss)
  clinical_status String @default("none")

  /// Vorbereitungsdurchläufe dieses Falls. Wird in Schritt 1 noch nicht von
  /// bestehenden Routen geschrieben; siehe `lib/server/prefillRuns.ts`.
  prefill_runs PrefillRun[]
}

enum InquirySessionStatus {
  DRAFT
  CONFIRMED
  ARCHIVED
}

/// Modulare Fragebogen-Sitzung für einen Patienten.
/// Vollständig isoliert von CaseSession und InquirySession.
/// Wird über einen einmaligen, zeitlich begrenzten Token zugänglich gemacht.
model PatientQuestionnaireSession {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Einmaliger Token für den Patientenlink (wird nach Einreichung auf null gesetzt)
  token String? @unique

  /// Ablaufzeitpunkt des Tokens
  token_expires_at DateTime?

  /// Ersteller (Praxis-Account, Pflichtfeld).
  /// Phase 2: NOT NULL, damit jede Session eindeutig einer Praxis zugeordnet bleibt.
  /// onDelete: Restrict → Account-Löschung wird blockiert, solange Sessions existieren.
  /// Vor einem zukünftigen Account-Lösch-Workflow müssen die Sessions explizit
  /// gelöscht oder umgehängt werden; es gibt absichtlich kein automatisches Cascade,
  /// damit medizinisch dokumentationspflichtige Daten nicht still verschwinden.
  owner_account_id String
  owner_account    Account @relation(fields: [owner_account_id], references: [id], onDelete: Restrict)

  /// Phase P1 (additiv): Verknüpfung zum Mandanten (Practice). Nullable in
  /// P1, damit die Migration mit Bestandsdaten bedingungslos kompatibel ist;
  /// `NOT NULL` folgt in P5. App-Logik nutzt dieses Feld in P1 nicht.
  owner_practice_id String?
  owner_practice    Practice? @relation("PatientQuestionnaireSessionOwnerPractice", fields: [owner_practice_id], references: [id], onDelete: Restrict)

  /// Interne Patientenreferenz (wird nie in den Link kodiert)
  patient_reference String?

  /// Optionale Verknüpfung zur auslösenden InquirySession
  inquiry_session_id String?

  /// Gewählte Block-IDs: z.B. ["KONTAKT", "AU"]
  selected_block_ids Json

  /// Deduplizierte Fragen (eingefroren beim Anlegen)
  deduplicated_questions Json

  /// Patientenantworten: Record<questionId, string> (nach Einreichung)
  answers Json?

  /// "pending" | "completed" | "expired"
  status String @default("pending")

  /// Zeitpunkt der Einreichung durch den Patienten
  submitted_at DateTime?

  /// Wer den Fragebogen eingereicht hat: "patient" | "contact_person"
  submitted_by String @default("patient")

  /// Optionaler Verifikations-Hash (SHA-256 des Geburtsdatums, nie Klartext)
  birth_date_hash String?

  /// Zeitpunkt des erfolgreichen IdentityGate-Durchlaufs (nur Zeitstempel, keine Eingabewerte)
  identity_gate_completed_at DateTime?

  /// Methode der Identitätsabfrage (Audit-Merkmal, keine personenbezogenen Daten)
  identity_gate_method String? @default("dob_lastname3")

  /// Phase 3a: Quelle der Session.
  /// Whitelist: "internal_link" (interner Praxis-Link, bisheriges Verhalten)
  /// | "website" (öffentliches Website-Formular, ab Phase 3b genutzt).
  /// Default ist "internal_link", damit Bestandszeilen und alle bestehenden
  /// Codepfade unverändert klassifiziert sind. Kein DB-Enum, konsistent zu
  /// `PrefillRun.source` und `CaseSession.preparation_mode`.
  source String @default("internal_link")

  /// Phase 3a: Optionale Verknüpfung zum öffentlichen Praxis-Formular.
  /// NULL für `source = "internal_link"`. Für `source = "website"` wird die
  /// Verknüpfung in Phase 3b (Submit-Flow) durch die Service-Schicht
  /// erzwungen; in Phase 3a existiert noch kein Schreibpfad.
  /// onDelete: Restrict — verhindert das stille Verschwinden zugeordneter
  /// Sessions, analog zur Konvention bei `owner_account`.
  practice_form_id String?
  practice_form    PracticeQuestionnaireForm? @relation(fields: [practice_form_id], references: [id], onDelete: Restrict)

  /// Phase 3a: Einmaliger Bestätigungs-Token für die Doppel-Opt-In-Bestätigung
  /// einer Website-Einreichung (Phase 3b). NULL für interne Sessions.
  confirm_token            String?   @unique
  /// Ablaufzeitpunkt des Bestätigungs-Tokens.
  confirm_token_expires_at DateTime?
  /// Zeitpunkt der erfolgreichen Bestätigung durch den Einreichenden.
  confirmed_at             DateTime?

  /// Phase 3a: SHA-256-Hash der vom Einreichenden angegebenen E-Mail-Adresse
  /// (nie Klartext; für Spam-/Doppel-Schutz und Auditierung).
  submitter_email_hash String?

  /// Sprache der Patientensicht beim Ausfüllen des Token-Fragebogens.
  /// Whitelist: "de" | "en". Default "de", damit Bestandszeilen und alle
  /// bestehenden Codepfade unverändert deutsch bleiben.
  /// Praxis-/interne Sichten (Übersicht, PDF, Krankenblatt) ignorieren
  /// dieses Feld bewusst und bleiben deutsch.
  patient_language String @default("de")

  /// Soft-Delete-Marker. NULL = aktiv, gesetzter Zeitstempel = archiviert.
  /// Praxis-/Patienten-Pfade behandeln Datensätze mit `deleted_at != null`
  /// wie nicht existent (404). Es gibt bewusst keine UI zum Wiederherstellen;
  /// die Spalte dient als kurzfristiges Sicherheitsnetz gegen versehentliches
  /// Löschen und kann später durch einen Cleanup-Job endgültig entfernt werden.
  deleted_at DateTime? @db.Timestamp(6)

  /// Bedient die Praxis-Listenabfrage `/questionnaires`
  /// (Filter `owner_account_id`, Sortierung `createdAt desc`).
  @@index([owner_account_id, createdAt])
  /// Phase P1 (additiv): Index analog zum bestehenden Owner-Index, damit
  /// spätere Pfad-Umstellungen ohne Schema-Touch direkt performant filtern
  /// können. Wird in P1 noch nicht genutzt.
  @@index([owner_practice_id, createdAt])
}

/// Phase 3a: Öffentliches Website-Fragebogen-Formular einer Praxis.
/// Wird in Phase 3a nur als Datenstruktur eingeführt; es gibt noch keine
/// öffentliche Route `/p/[slug]`, keinen Submit-Endpoint und keine
/// Praxis-UI zum Anlegen. In Phase 3a sind Datensätze ausschließlich
/// per direkter DB-Manipulation erzeugbar; ohne Folgephasen sind sie
/// ohne sichtbare Wirkung.
model PracticeQuestionnaireForm {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Praxis-Account, der das Formular besitzt. Pflichtfeld.
  /// onDelete: Restrict — analog zu `PatientQuestionnaireSession.owner_account`.
  owner_account_id String
  owner_account    Account @relation(fields: [owner_account_id], references: [id], onDelete: Restrict)

  /// Phase P1 (additiv): Verknüpfung zum Mandanten (Practice). Nullable in
  /// P1, `NOT NULL` folgt in P5. App-Logik nutzt dieses Feld in P1 nicht.
  owner_practice_id String?
  owner_practice    Practice? @relation("PracticeQuestionnaireFormOwnerPractice", fields: [owner_practice_id], references: [id], onDelete: Restrict)

  /// Global eindeutiger URL-Slug. Wird in Phase 3b für `/p/[slug]` genutzt.
  slug String @unique

  /// Anzeigetitel im Formular.
  title String

  /// Gewählte Block-IDs analog `PatientQuestionnaireSession.selected_block_ids`.
  selected_block_ids Json

  /// Optionaler Einleitungstext, der über dem Formular angezeigt wird.
  intro_text String?

  /// Aktiv-Flag: ein deaktiviertes Formular ist auch in Phase 3b nicht
  /// öffentlich aufrufbar (für Phase 3a verhaltensirrelevant).
  is_active Boolean @default(true)

  patient_questionnaire_sessions PatientQuestionnaireSession[]

  @@index([owner_account_id, createdAt])
  /// Phase P1 (additiv): Index analog zum bestehenden Owner-Index.
  @@index([owner_practice_id, createdAt])
}

/// Sitzung des Anfrage-Assistenten.
/// JSON-Felder werden bewusst verwendet, da die Checkpoint-Struktur
/// noch in der Validierungsphase ist. Keine Einzeltabellen für Checkpoints.
model InquirySession {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Optionale Verknüpfung zum eingeloggten Account.
  owner_account_id String?
  owner_account    Account? @relation(fields: [owner_account_id], references: [id], onDelete: SetNull)

  /// Phase P1 (additiv): Verknüpfung zum Mandanten (Practice). Per Backfill
  /// aus der OWNER-Membership zum bisherigen `owner_account_id` abgeleitet.
  /// App-Logik nutzt dieses Feld in P1 noch nicht.
  owner_practice_id String?
  owner_practice    Practice? @relation("InquirySessionOwnerPractice", fields: [owner_practice_id], references: [id], onDelete: SetNull)

  status InquirySessionStatus @default(DRAFT)

  /// Liste der ausgewählten Anliegen-IDs (z. B. ["AU"]).
  selected_inquiry_ids Json?

  /// Snapshot der Anliegen-Abschnitte zum Zeitpunkt der Generierung.
  section_snapshot Json?

  /// Checkpoint-Statuses: Record<checkpointId, StatusValue>.
  checkpoint_statuses Json?

  /// Aktions-Statuses: Record<actionId, ActionStatus>.
  action_statuses Json?

  /// outputStatus-Entscheidungen von M3 für EXPLANATION-Checkpoints.
  /// Record<checkpointId, "SHOW" | "HIDE"> – Ausgabe nur bei SHOW.
  explanation_output_statuses Json?

  /// M1B – Kommunikationsanlass-Auswahl pro Profil (menschliche Auswahl).
  /// Record<inquiryId, communicationReasonId>
  communication_reason_selection Json?

  /// M3 – Antwortziel-Auswahl pro Profil (menschliche Auswahl).
  /// Record<inquiryId, responseGoalId>
  response_goal_selection Json?

  generated_output Json?

  /// Zeitpunkt der Bestätigung (gesetzt zusammen mit status = CONFIRMED).
  confirmed_at DateTime?

  /// Vorlagen-Markierung. Vorlagen erscheinen in der Übersicht
  /// (Patientenkommunikation → Vorlagen) und werden nicht als reguläre
  /// Arbeits-Sessions behandelt. Reguläre Sessions (is_template=false)
  /// laufen den normalen DRAFT/CONFIRMED-Lifecycle und tauchen in der
  /// sichtbaren Liste nicht auf.
  is_template Boolean @default(false)

  /// Optionaler, vom Nutzer vergebener Vorlagenname (Pflicht, sobald
  /// is_template=true; wird im Service validiert).
  template_name String?

  @@index([owner_account_id, is_template])
}

/// Phase P1: Mandant ("Praxis"). Wird in P1 ausschließlich per Backfill aus
/// bestehenden `Account`-Datensätzen erzeugt (1:1). Die App nutzt diese
/// Tabelle in P1 noch nicht; Lese- und Schreibpfade laufen weiterhin über
/// `Account`. Die Feature-Flags werden vom Account 1:1 übernommen, damit
/// in den Folgephasen ohne Sichtbarkeitsänderung umgestellt werden kann.
model Practice {
  id   String @id @default(cuid())
  /// Anzeigename. Initialer Backfill-Wert: `Account.email` (manuelle
  /// Politur vor P3-Cutover).
  name String
  /// Global eindeutiger, URL-tauglicher Bezeichner. Initialer Backfill-Wert:
  /// slugifizierte E-Mail + Kurzform der Account-Id, damit Kollisionen
  /// strukturell ausgeschlossen sind.
  slug String @unique

  /// Carry-Over aus `Account.is_approved`. Default `false` für neue Inserts.
  is_approved                   Boolean @default(false)
  /// Carry-Over aus `Account.inquiry_assistant_enabled`.
  inquiry_assistant_enabled     Boolean @default(false)
  /// Carry-Over aus `Account.patient_communication_enabled`.
  patient_communication_enabled Boolean @default(false)
  /// Carry-Over aus `Account.website_forms_enabled`.
  website_forms_enabled         Boolean @default(false)

  /// Praxis-spezifische SMTP-Konfiguration für Bestätigungs-E-Mails der
  /// Website-Formulare. Alle Felder sind nullable; eine Konfiguration gilt
  /// erst dann als „vollständig", wenn alle Pflichtfelder (Host, Port,
  /// User, Pass, From-Email) gesetzt sind — diese Validierung erfolgt im
  /// App-Layer (`lib/mail/practiceSmtp.ts`), nicht in der DB.
  ///
  /// Sicherheits-Invariante: `smtp_pass_encrypted` enthält das per
  /// AES-256-GCM mit `MAIL_SECRET_KEY` verschlüsselte Passwort im
  /// Format `v1:<base64(iv)>:<base64(ciphertext)>:<base64(authTag)>`.
  /// Klartext-Passwörter werden niemals persistiert oder geloggt.
  smtp_host           String?
  smtp_port           Int?
  smtp_secure         Boolean?
  smtp_user           String?
  smtp_pass_encrypted String?
  smtp_from_email     String?
  smtp_from_name      String?
  smtp_updated_at     DateTime?

  /// Freitext-Signatur für Nachrichten (max. 300 Zeichen, praxis-bezogen).
  /// Wird per UI im Praxis-Admin-Bereich (`/practice/signature`) bearbeitet
  /// (Berechtigung: OWNER/ADMIN); USER der Praxis dürfen sie lesen, damit
  /// sie in den Fall-Flows (M2/M3) automatisch an Patientennachrichten
  /// angehängt werden kann.
  /// Backfill: pro Practice aus `Account.message_signature` der OWNER-,
  /// sonst ADMIN-, sonst ältesten Membership übernommen.
  message_signature String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  memberships                    PracticeMembership[]
  case_sessions                  CaseSession[]                 @relation("CaseSessionOwnerPractice")
  inquiry_sessions               InquirySession[]              @relation("InquirySessionOwnerPractice")
  patient_questionnaire_sessions PatientQuestionnaireSession[] @relation("PatientQuestionnaireSessionOwnerPractice")
  practice_questionnaire_forms   PracticeQuestionnaireForm[]   @relation("PracticeQuestionnaireFormOwnerPractice")

  /// Option C (minimal): Accounts, die diese Practice als Standard-Praxis
  /// referenzieren. Gegenseite zu `Account.default_practice`.
  default_for_accounts Account[] @relation("AccountDefaultPractice")
}

/// Phase P1: Mitgliedschaft eines Accounts in einer Practice.
/// Backfill legt pro Account genau eine Membership mit Rolle `OWNER` an.
/// Pro (account, practice)-Paar darf es nur eine Rolle geben.
model PracticeMembership {
  id String @id @default(cuid())

  account_id String
  account    Account @relation(fields: [account_id], references: [id], onDelete: Cascade)

  practice_id String
  practice    Practice @relation(fields: [practice_id], references: [id], onDelete: Cascade)

  role PracticeRole

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([account_id, practice_id])
  @@index([practice_id, role])
}
