generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum StageStatus {
  INTAKE
  PREFILL
  REVIEW
  READY
  CLOSED
}

model Account {
  id                String        @id @default(cuid())
  email             String        @unique
  is_approved       Boolean       @default(false)
  is_admin          Boolean       @default(false)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  /// Freitext-Signatur für Nachrichten (max. 300 Zeichen, accountbezogen)
  message_signature String?

  /// Freigabe für den Anfrage-Assistenten (separater zweiter Modus).
  /// Muss explizit durch Admin aktiviert werden; Standard: false.
  inquiry_assistant_enabled Boolean @default(false)

  cases             CaseSession[]
  sessions          Session[]
  inquiry_sessions  InquirySession[]
}

model Session {
  id         String   @id @default(cuid())
  token      String   @unique
  account_id String
  account    Account  @relation(fields: [account_id], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  expiresAt  DateTime
}

/// Ein einzelner Vorbereitungsdurchlauf eines Falls (MFA, Patientengespräch,
/// Patientenfragebogen, …). Ein Fall kann mehrere nacheinander abgeschlossene
/// Runs haben. Ein eingefrorener Run (`frozen_at IS NOT NULL`) ist
/// unveränderlich. Pro Fall darf höchstens **ein** offener Run
/// (`frozen_at IS NULL`) existieren – durchgesetzt über einen partiellen
/// Unique-Index in der Migration (Prisma kennt partielle Unique-Indexe nicht
/// nativ). Die Reihenfolge wird über `sequence` (1..n, lückenfrei pro Fall)
/// abgebildet.
model PrefillRun {
  id                    String       @id @default(cuid())

  /// Fall, zu dem dieser Run gehört.
  case_id               String
  case                  CaseSession  @relation(fields: [case_id], references: [id], onDelete: Cascade)

  /// Position innerhalb des Falls (1..n, monoton, lückenfrei).
  sequence              Int

  /// Quelle/Modus des Runs: "mfa" | "conversation" | "patient".
  /// Kein DB-Enum, weil das Schwester-Feld `CaseSession.preparation_mode`
  /// ebenfalls als String geführt wird; Whitelist-Validierung erfolgt in
  /// der Service-Schicht.
  source                String

  /// Snapshot der zum Zeitpunkt des Runs aktiven Checkpoints
  /// (Form analog `CaseSession.active_checkpoints`). Dadurch werden
  /// eingefrorene Runs nicht durch spätere M1-Änderungen umgedeutet.
  active_checkpoints    Json

  /// Antworten dieses Runs. Form analog `CaseSession.ctx_prefill`:
  /// `{ [checkpointId]: { [questionId]: "ja" | "nein" | "unklar" | "offen" } }`.
  answers               Json

  created_at            DateTime     @default(now())

  /// Zeitpunkt des Einfrierens. `NULL` = offener Run.
  frozen_at             DateTime?

  /// Account, der den Run angelegt hat. NULL bei Patientenrücklauf via Token.
  created_by_account_id String?

  /// Optionales Audit: Token-Wert, mit dem ein Patientenrücklauf zugeordnet
  /// wurde. NULL bei MFA-/Conversation-Runs.
  patient_token_used    String?

  @@unique([case_id, sequence])
  @@index([case_id, frozen_at, sequence])
}

model CaseSession {
  id                   String      @id @default(cuid())
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  /// Roheingabe / Anlass der Session (neutraler Freitext)
  query_raw            String?

  /// Grober Workflow-Status
  stage_status         StageStatus @default(INTAKE)

  /// Übersicht der Block-Zustände (JSON-Anker)
  block_status_anchor  Json?

  /// Aktive Checkpoints im aktuellen Workflow-Schritt (JSON-Anker)
  active_checkpoints   Json?

  /// Prefill- / Kontextdaten für Blöcke (JSON-Anker)
  ctx_prefill          Json?

  /// Bestätigte finale Daten der Session (JSON-Anker)
  ctx_final            Json?

  /// Optionale Zusammenfassung / Summary (JSON-Anker)
  summary_anchor       Json?

  /// Eingefrorener M1-Aktivierungsstand bei Fallanlage (unveränderlich nach Erstellung)
  m1_snapshot_initial  Json?

  /// Startmodus: "guest" (kein Patientenbezug) oder "practice" (Praxiszuordnung)
  mode                 String?   @default("guest")

  /// Optionale Patientennummer / Referenz (nur bei mode = "practice")
  patient_reference    String?

  /// Verknüpfung zum eingeloggten Account (optional, bestehende Fälle bleiben erhalten)
  owner_account_id     String?
  owner_account        Account?  @relation(fields: [owner_account_id], references: [id], onDelete: SetNull)

  /// Einmaliges Token für den patientenseitigen M2-Link (ohne Login)
  m2_token             String?   @unique

  /// Ablaufdatum des M2-Tokens (14 Tage ab Erstellung)
  m2_token_expires_at  DateTime?

  /// Status des Patientenfragebogens: none | waiting_for_patient | skipped | completed
  m2_status            String    @default("none")

  /// Vorbereitungsweg: none | mfa | patient | skipped
  preparation_mode     String    @default("none")

  /// Ärztliche Bestätigung: nach Klick auf „Ärztlich bestätigt" wird M3 eingefroren.
  doctor_confirmed     Boolean   @default(false)

  /// Zeitpunkt der ärztlichen Bestätigung (gesetzt zusammen mit doctor_confirmed=true).
  doctor_confirmed_at  DateTime?

  /// Ärztlicher Workflow-Zwischenstatus: none | prepared | confirmed
  /// - "prepared" : Arzt hat in M3 vorbereitet / Lücken markiert (MFA übernimmt weiter)
  /// - "confirmed": Arzt hat M3 final geprüft (fachlicher Abschluss)
  clinical_status      String    @default("none")

  /// Vorbereitungsdurchläufe dieses Falls. Wird in Schritt 1 noch nicht von
  /// bestehenden Routen geschrieben; siehe `lib/server/prefillRuns.ts`.
  prefill_runs         PrefillRun[]
}

enum InquirySessionStatus {
  DRAFT
  CONFIRMED
  ARCHIVED
}

/// Sitzung des Anfrage-Assistenten.
/// JSON-Felder werden bewusst verwendet, da die Checkpoint-Struktur
/// noch in der Validierungsphase ist. Keine Einzeltabellen für Checkpoints.
model InquirySession {
  id String @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Optionale Verknüpfung zum eingeloggten Account.
  owner_account_id String?
  owner_account    Account? @relation(fields: [owner_account_id], references: [id], onDelete: SetNull)

  status InquirySessionStatus @default(DRAFT)

  /// Liste der ausgewählten Anliegen-IDs (z. B. ["AU"]).
  selected_inquiry_ids Json?

  /// Snapshot der Anliegen-Abschnitte zum Zeitpunkt der Generierung.
  section_snapshot Json?

  /// Checkpoint-Statuses: Record<checkpointId, StatusValue>.
  checkpoint_statuses Json?

  /// Aktions-Statuses: Record<actionId, ActionStatus>.
  action_statuses Json?

  /// Generierter Output (renderInquiryResponseFromSections-Ergebnis).
  generated_output Json?

  /// Zeitpunkt der Bestätigung (gesetzt zusammen mit status = CONFIRMED).
  confirmed_at DateTime?
}
